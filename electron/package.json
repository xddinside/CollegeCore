{
  "name": "collegecore-electron",
  "version": "0.1.0",
  "private": true,
  "description": "CollegeCore desktop shell",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && cross-env NODE_ENV=production ELECTRON_DEVTOOLS=1 electron .",
    "dist": "npm run build && electron-builder --config electron-builder.yml"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "cross-env": "^10.1.0",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3"
  }
}
